@model EventEase.Models.Booking

@{
    ViewData["Title"] = "Delete Booking";
}

<h1>Delete Booking</h1>

<h3 class="text-danger">
    Are you sure you want to delete this booking?
</h3>

<div asp-validation-summary="All" class="text-danger"></div>

<div>
    <dl class="row">
        <dt class="col-sm-2">Event</dt>
        <dd class="col-sm-10">@Model.Event?.Name</dd>

        <dt class="col-sm-2">Venue</dt>
        <dd class="col-sm-10">@Model.Venue?.Location</dd>

        <dt class="col-sm-2">Date</dt>
        <dd class="col-sm-10">@Model.BookingDate</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="BookingID" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index">Back</a>
    </form>
</div>