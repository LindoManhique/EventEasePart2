@model EventEase.Models.Event

@{
    ViewData["Title"] = "Create Event";
}

<h1>Create Event</h1>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        Please fix the errors below.
    </div>
}

<div class="row">
    <div class="col-md-4">

        <form asp-action="Create" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Name"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Date"></label>
                <input asp-for="Date" class="form-control" />
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

         
            <div class="form-group">
                <label asp-for="EventTypeID">Event Type</label>

                <select asp-for="EventTypeID" class="form-control">
                    <option value="">-- Select Event Type --</option>

                    @foreach (var type in ViewBag.EventTypes)
                    {
                        <option value="@type.EventTypeID">
                            @type.Name
                        </option>
                    }
                </select>

                <span asp-validation-for="EventTypeID" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Event Image</label>
                <input type="file" name="imageFile" class="form-control" />
            </div>

            <br />

            <button type="submit" class="btn btn-primary">Create</button>
        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}