@model EventEase.Models.Venue

@{
    ViewData["Title"] = "Edit Venue";
}

<h1>Edit Venue</h1>

@if (ViewData.ModelState.ErrorCount > 0)
{
    <div class="alert alert-danger">
        Cannot save changes. Please fix errors.
    </div>
}

<form asp-action="Edit" method="post" enctype="multipart/form-data">

    <input type="hidden" asp-for="VenueID" />
    <input type="hidden" asp-for="ImageUrl" />

    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="form-group">
        <label asp-for="Location"></label>
        <input asp-for="Location" class="form-control" />
        <span asp-validation-for="Location" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Capacity"></label>
        <input asp-for="Capacity" class="form-control" />
        <span asp-validation-for="Capacity" class="text-danger"></span>
    </div>

    <div class="mt-3">
        <label>Current Image</label>

        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" style="width:200px;height:120px;" />

            <div class="form-check">
                <input type="checkbox" name="deleteImage" value="true" />
                <label class="text-danger">Delete Image</label>
            </div>
        }
        else
        {
            <p>No image</p>
        }
    </div>

    <div class="mt-3">
        <label>Change Image</label>
        <input type="file" name="imageFile" class="form-control" />
    </div>

    <br />

    <button type="submit" class="btn btn-primary">Save</button>

</form>