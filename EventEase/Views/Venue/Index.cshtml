@model IEnumerable<EventEase.Models.Venue>

@{
    ViewData["Title"] = "Venues";
}

<h1>Venues</h1>

<!-- FILTER -->
<form method="get" asp-action="Index" class="mb-3">

    <label>
        <input type="checkbox"
               name="onlyAvailable"
               value="true"
        @(ViewBag.OnlyAvailable == true ? "checked" : "") />
        Only Available Venues (no bookings)
    </label>

    <button type="submit" class="btn btn-primary btn-sm">Filter</button>

    <a asp-action="Index" class="btn btn-secondary btn-sm">Reset</a>
</form>

<!-- ALERTS -->
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Venue</a>
</p>

<table class="table table-striped table-bordered align-middle">
    <thead class="table-dark">
        <tr>
            <th>Location</th>
            <th>Capacity</th>
            <th>Image</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Location</td>
                <td>@item.Capacity</td>

                <td>
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl"
                             width="100"
                             height="80"
                             style="object-fit:cover;border-radius:6px;" />
                    }
                    else
                    {
                        <span class="text-muted">No Image</span>
                    }
                </td>

                <td>
                    <a asp-action="Edit" asp-route-id="@item.VenueID" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.VenueID" class="btn btn-info btn-sm">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.VenueID" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>